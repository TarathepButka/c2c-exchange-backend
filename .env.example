# ===== Database (PostgreSQL) =====
POSTGRES_DB="c2c_exchange"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_PORT="15432"
DATABASE_URL="postgresql://postgres:postgres@localhost:15432/c2c_exchange?schema=public"

# ===== JWT (Authentication) =====
JWT_SECRET="change-me-in-production"
